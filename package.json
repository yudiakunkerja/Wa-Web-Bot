{
  "name": "wa-ai-bot",
  "version": "1.0.0",
  "description": "WhatsApp Web Auto-Reply Bot dengan AI Agent (OpenAI/Gemini) - Deploy ke Railway/Render",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo 'No build step required'",
    "clean": "rm -rf node_modules package-lock.json .wwebjs_auth .wwebjs_cache",
    "reset": "npm run clean && npm install",
    "docker:build": "docker build -t wa-ai-bot .",
    "docker:run": "docker run -p 3000:3000 --env-file .env wa-ai-bot",
    "docker:dev": "docker-compose up"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-web",
    "whatsapp-bot",
    "bot",
    "ai",
    "ai-agent",
    "openai",
    "gpt",
    "gemini",
    "google-ai",
    "auto-reply",
    "chatbot",
    "railway",
    "render",
    "docker"
  ],
  "author": {
    "name": "Nama Kamu",
    "email": "email@example.com",
    "url": "https://github.com/username"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/wa-ai-bot.git"
  },
  "bugs": {
    "url": "https://github.com/username/wa-ai-bot/issues"
  },
  "homepage": "https://github.com/username/wa-ai-bot#readme",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "openai": "^4.73.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.4.1"
  },
  "optionalDependencies": {},
  "peerDependencies": {},
  "config": {
    "bot": {
      "name": "WhatsApp AI Bot",
      "version": "1.0.0"
    }
  }
}
